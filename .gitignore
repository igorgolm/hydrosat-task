# Terraform local state — NEVER commit to git
*.tfstate
*.tfstate.backup

# Terraform plan files
*.tfplan

# tfvars with secrets — commit only non-sensitive .tfvars (e.g., terraform.tfvars)
# Override files take precedence and may contain secrets
*.override.tf
*.override.tf.json
override.tf
override.tf.json

# Terraform working directory
**/.terraform/
**/.terraform.lock.hcl

# Crash log files
crash.log
crash.*.log

# Sensitive variable files
*.tfvars.json
secret.*.tfvars

# Editor and OS
.DS_Store
.idea/
*.iml
.vscode/
